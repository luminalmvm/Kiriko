<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox off and library validation disabled: the bridge dlopens an
	     unsigned, locally-built liblumit_bridge.dylib from the Cargo target
	     dir (bridge.dart _candidatePaths), which a sandboxed/hardened-runtime
	     process would refuse. Matches the unsigned, unsandboxed dev posture
	     Windows/Linux already have; revisit once a signed macOS release
	     exists. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
